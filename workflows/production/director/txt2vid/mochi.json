{
  "$musebotDefaults": {
    "prompt": "",
    "promptNegative": "",
    "model": "",
    "seed": -1,
    "width": 848,
    "height": 480,
    "sampler": "euler",
    "scheduler": "linear-quadratic",
    "cfgScale": 7,
    "steps": 20,
    "num": 1
  },
  "4": {
    "inputs": {
      "ckpt_name": "Mochi/mochi_preview_fp8_scaled.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "Load Checkpoint"
    }
  },
  "5": {
    "inputs": {
      "width": "{{{ width }}}",
      "height": "{{{ height }}}",
      "length": 121,
      "batch_size": "{{{ num }}}"
    },
    "class_type": "EmptyMochiLatentVideo",
    "_meta": {
      "title": "EmptyMochiLatentVideo"
    }
  },
  "6": {
    "inputs": {
      "text": "{{{ prompt }}}",
      "clip": ["4", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Prompt)"
    }
  },
  "7": {
    "inputs": {
      "text": "{{{ promptNegative }}}",
      "clip": ["4", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Prompt)"
    }
  },
  "8": {
    "inputs": {
      "tile_size": 160,
      "overlap": 96,
      "temporal_size": 64,
      "temporal_overlap": 8,
      "samples": ["10", 0],
      "vae": ["4", 2]
    },
    "class_type": "VAEDecodeTiled",
    "_meta": {
      "title": "VAE Decode (Tiled)"
    }
  },
  "10": {
    "inputs": {
      "noise_seed": "{{{ seed }}}",
      "steps": "{{{ steps }}}",
      "cfg": "{{{ cfgScale }}}",
      "sampler_name": "{{{ sampler }}}",
      "scheduler": "{{{ scheduler }}}",
      "start_at_step": 0,
      "end_at_step": 10000,
      "var_seed": 0,
      "var_seed_strength": 0,
      "sigma_max": -1,
      "sigma_min": -1,
      "rho": 7,
      "add_noise": "enable",
      "return_with_leftover_noise": "disable",
      "previews": "animate",
      "tile_sample": false,
      "tile_size": 848,
      "model": ["4", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "SwarmKSampler",
    "_meta": {
      "title": "SwarmKSampler"
    }
  },
  "11": {
    "inputs": {
      "value": ["8", 0]
    },
    "class_type": "UnloadAllModels",
    "_meta": {
      "title": "UnloadAllModels"
    }
  },
  "12": {
    "inputs": {
      "filename_prefix": "Musebot_Mochi",
      "fps": 24,
      "lossless": false,
      "quality": 85,
      "method": "default",
      "images": ["11", 0]
    },
    "class_type": "SaveAnimatedWEBP",
    "_meta": {
      "title": "SaveAnimatedWEBP"
    }
  }
}
