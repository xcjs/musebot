{
  "$musebotDefaults": {
    "prompt": "",
    "promptNegative": "",
    "model": "",
    "seed": -1,
    "width": 684,
    "height": 1024,
    "sampler": "euler",
    "scheduler": "simple",
    "cfgScale": 3.5,
    "steps": 20,
    "num": 1
  },
  "4": {
    "inputs": {
      "unet_name": "Flux.1/Dev/flux1-dev-Q8_0.gguf"
