    "class_type": "SwarmKSampler",
    "_meta": {
      "title": "SwarmKSampler"
    }
  },
  "100": {
    "inputs": {
      "clip_name1": "t5xxl_enconly.safetensors",
      "clip_name2": "clip_l.safetensors",
