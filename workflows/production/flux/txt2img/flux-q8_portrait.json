    "class_type": "SaveImage",
    "_meta": {
      "title": "Save Image"
    }
  },
  "108": {
    "inputs": {
      "value": ["8", 0]
    },
    "class_type": "UnloadAllModels",
    "_meta": {
      "title": "UnloadAllModels"
