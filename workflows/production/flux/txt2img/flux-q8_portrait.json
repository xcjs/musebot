      "end_at_step": 10000,
      "var_seed": 0,
      "var_seed_strength": 0,
      "sigma_max": -1,
      "sigma_min": -1,
      "rho": 7,
      "add_noise": "enable",
      "return_with_leftover_noise": "enable",
      "previews": "default",
      "tile_sample": false,
      "tile_size": 1024,
      "model": ["4", 0],
      "positive": ["105", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
