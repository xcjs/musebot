{
  "$musebotDefaults": {
    "prompt": "",
    "promptNegative": "",
    "model": "",
    "seed": -1,
    "width": 1024,
    "height": 1024,
    "sampler": "euler",
    "scheduler": "simple",
    "cfgScale": 7,
    "steps": 20,
    "num": 1
  },
  "4": {
    "inputs": {
      "ckpt_name": "SDXL-Turbo/General/dreamshaperXL_v21TurboDPMSDE.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "Load Checkpoint"
    }
  },
  "5": {
    "inputs": {
      "width": "{{{ width }}}",
      "height": "{{{ height }}}",
      "batch_size": "{{{ num }}}"
    },
    "class_type": "EmptyLatentImage",
    "_meta": {
      "title": "Empty Latent Image"
    }
  },
  "6": {
    "inputs": {
      "text": "{{{ prompt }}}",
      "clip": ["4", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Prompt)"
    }
  },
  "7": {
    "inputs": {
      "text": "{{{ promptNegative }}}",
      "clip": ["4", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Prompt)"
    }
  },
  "8": {
    "inputs": {
      "samples": ["10", 0],
      "vae": ["4", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "10": {
    "inputs": {
      "noise_seed": "{{{ seed }}}",
      "steps": "{{{ steps }}}",
      "cfg": "{{{ cfgScale }}}",
      "sampler_name": "{{{ sampler }}}",
      "scheduler": "{{{ scheduler }}}",
      "start_at_step": 0,
      "end_at_step": 10000,
      "var_seed": 0,
      "var_seed_strength": 0,
      "sigma_max": -1,
      "sigma_min": -1,
      "rho": 7,
      "add_noise": "enable",
      "return_with_leftover_noise": "disable",
      "previews": "default",
      "tile_sample": false,
      "tile_size": 1024,
      "model": ["4", 0],
      "positive": ["6", 0],
      "negative": ["100", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "SwarmKSampler",
    "_meta": {
      "title": "SwarmKSampler"
    }
  },
  "100": {
    "inputs": {
      "conditioning": ["7", 0]
    },
    "class_type": "ConditioningZeroOut",
    "_meta": {
      "title": "ConditioningZeroOut"
    }
  },
  "101": {
    "inputs": {
      "ckpt_name": "SVD/stableVideoDiffusion_img2vidXt11.safetensors"
    },
    "class_type": "ImageOnlyCheckpointLoader",
    "_meta": {
      "title": "Image Only Checkpoint Loader (img2vid model)"
    }
  },
  "102": {
    "inputs": {
      "min_cfg": 1,
      "model": ["101", 0]
    },
    "class_type": "VideoLinearCFGGuidance",
    "_meta": {
      "title": "VideoLinearCFGGuidance"
    }
  },
  "103": {
    "inputs": {
      "width": 768,
      "height": 768,
      "video_frames": 25,
      "motion_bucket_id": 127,
      "fps": 6,
      "augmentation_level": 0,
      "clip_vision": ["101", 1],
      "init_image": ["8", 0],
      "vae": ["101", 2]
    },
    "class_type": "SVD_img2vid_Conditioning",
    "_meta": {
      "title": "SVD_img2vid_Conditioning"
    }
  },
  "104": {
    "inputs": {
      "noise_seed": "{{{ seed }}}",
      "steps": 40,
      "cfg": 2.5,
      "sampler_name": "{{{ sampler }}}",
      "scheduler": "{{{ scheduler }}}",
      "start_at_step": 0,
      "end_at_step": 10000,
      "var_seed": 0,
      "var_seed_strength": 0,
      "sigma_max": 1000,
      "sigma_min": 0.002,
      "rho": 7,
      "add_noise": "enable",
      "return_with_leftover_noise": "disable",
      "previews": "animate",
      "tile_sample": false,
      "tile_size": 1024,
      "model": ["102", 0],
      "positive": ["103", 0],
      "negative": ["103", 1],
      "latent_image": ["103", 2]
    },
    "class_type": "SwarmKSampler",
    "_meta": {
      "title": "SwarmKSampler"
    }
  },
  "105": {
    "inputs": {
      "samples": ["104", 0],
      "vae": ["101", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "107": {
    "inputs": {
      "filename_prefix": "Musebot_SVD_Dreamshaper",
      "fps": 6,
      "lossless": true,
      "quality": 95,
      "method": "default",
      "images": ["108", 0]
    },
    "class_type": "SaveAnimatedWEBP",
    "_meta": {
      "title": "SaveAnimatedWEBP"
    }
  },
  "108": {
    "inputs": {
      "value": ["105", 0]
    },
    "class_type": "UnloadAllModels",
    "_meta": {
      "title": "UnloadAllModels"
    }
  },
  "109": {
    "inputs": {
      "filename_prefix": "Musebot_Dreamshaper",
      "images": ["8", 0]
    },
    "class_type": "SaveImage",
    "_meta": {
      "title": "Save Image"
    }
  }
}