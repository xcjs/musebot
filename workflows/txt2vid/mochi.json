{
  "$musebotDefaults": {
    "prompt": "",
    "promptNegative": "",
    "model": "",
    "seed": -1,
    "width": 848,
    "height": 480,
    "sampler": "euler",
    "scheduler": "simple",
    "cfgScale": 7,
    "steps": 20,
    "num": 1
  },
  "4": {
    "inputs": {
      "ckpt_name": "Mochi/mochi_preview_fp8_scaled.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "Load Checkpoint"
    }
  },
  "5": {
    "inputs": {
      "width": 848,
      "height": 480,
      "length": 25,
      "batch_size": "{{ num }}"
    },
    "class_type": "EmptyMochiLatentVideo",
    "_meta": {
      "title": "EmptyMochiLatentVideo"
    }
  },
  "6": {
    "inputs": {
      "text": "{{ prompt }}",
      "clip": ["4", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Prompt)"
    }
  },
  "7": {
    "inputs": {
      "text": "{{ promptNegative }}",
      "clip": ["4", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Prompt)"
    }
  },
  "8": {
    "inputs": {
      "samples": ["10", 0],
      "vae": ["4", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "10": {
    "inputs": {
      "noise_seed": "{{ seed }}",
      "steps": "{{ seed }}",
      "cfg": "{{ cfgScale }}",
      "sampler_name": "{{ sampler }}",
      "scheduler": "{{ scheduler }}",
      "start_at_step": 0,
      "end_at_step": 10000,
      "var_seed": 0,
      "var_seed_strength": 0,
      "sigma_max": -1,
      "sigma_min": -1,
      "rho": 7,
      "add_noise": "enable",
      "return_with_leftover_noise": "disable",
      "previews": "animate",
      "tile_sample": false,
      "tile_size": 848,
      "model": ["4", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "SwarmKSampler",
    "_meta": {
      "title": "SwarmKSampler"
    }
  },
  "11": {
    "inputs": {
      "filename_prefix": "Musebot_Mochi",
      "fps": 5,
      "lossless": true,
      "quality": 95,
      "method": "default",
      "images": ["12", 0]
    },
    "class_type": "SaveAnimatedWEBP",
    "_meta": {
      "title": "SaveAnimatedWEBP"
    }
  },
  "12": {
    "inputs": {
      "value": ["8", 0]
    },
    "class_type": "UnloadAllModels",
    "_meta": {
      "title": "UnloadAllModels"
    }
  }
}
