# Discord App Token
TOKEN=

# The relative path of the Stable Diffusion model to use without the file
# extension. This should look like "model_name" or "path/model_name".
MODEL=

# The base URL of the EasyDiffusion instance. This can also be a comma-separated
# list. Include the closing slash in the format of "http(s)://easy-diffusion/"
# or "http(s)://instance1/,http(s)://instance2/"
EASYDIFFUSION_HOSTS=

# The Discord channel ID or a comma separated list of channel IDs.
CHANNELS=

# Whether the the bot requires users to "@" mention them to reply.
REQUIRES_MENTION=true

# Whether to always use a random server or enumerate servers in the list.
RANDOM_SERVER=false
