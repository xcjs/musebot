# Rename this file to .env if it isn't already.

# The current Node environment.
#
# Required: Required
# Type:     String
# Values:   production | development
NODE_ENV=production

# The number of times to retry a failed task.
#
# Required: Optional
# Default:  10
# Type:     Integer
MUSEBOT_TASK_QUEUE_MAX_ATTEMPTS=10

# The task retry delay in milliseconds for when a task fails.
#
# Required: Optional
# Type:     Integer
# Default:  1000
MUSEBOT_TASK_QUEUE_RETRY_DELAY_MS=1000

# Musebot's task queue supports both sequential (one by one) or parallel
# (multiple at the same time) tasks depending on how the below environment
# variables are configured. The (potentially) parallel queues are called
# "task channels". This is largely influenced by the hardware resources you have
# at your disposal to run Musebot and its supported services.
#
# If, for example, you are able to run Stable Diffusion image generation *and*
# Ollama large language model inferencing at the same time, you would assign
# each channel a unique name. This assigns them to separate channels.
#
# If are unable to run multiple types of models at once, you would assign them
# to the same channel name so that Musebot knows to wait for one task to finish
# before starting the other by assigning them to the same channel. Make sure the
# backend services you are using are configured to release memory resources as
# soon as possible if this is the case. Many solutions cache loaded resources to
# make subsequent requests respond faster.
#
# Regarding freeing up resources in supported backends:
#
# ComfyUI/SwarmUI: One of the recommended custom nodes in the documentation
# provides an "UnloadModel" and "UnloadAllModels" node. It is recommended to
# utilzie those nodes in your workflows.
#
# Ollama: Set the OLLAMA_KEEP_ALIVE environment variable to -1. Do not set this
# for Musebot, as it will do nothing - this is an Ollama setting.
#
# The channel names do not matter as long as they are either unique or identical
# when compared to each other.
#
# Additionally, you only need to configure task channels for services you are
# using or if you are using multiple resources (e.g. ComfyUI and Ollama).
#
# Required: Optional
# Type:     String

# Musebot primary functionality - if multiple APIs are integrated, this
# determines the main way Musebot can be interacted with. Is it a chat bot with
# image generation support, or is it an image generation bot with some chat
# features?
#
# * images (for image/video generation - videos are treated as animated images)
# * text (for large language model integration)
#
# Required: Required
# Type:     String
# Values:   images | text
MUSEBOT_FUNCTION=

# The Discord App Token used to authenticate as the bot you create in the
# Discord developer portal.
#
# Required: Required
# Type:     String
MUSEBOT_DISCORD_TOKEN=

# The Discord channel ID or a comma separated list of channel IDs the bot is
# allowed to reply in. If left blank, all channels will be allowed.
#
# Required: Optional
# Type:     Integer | Integer,Integer,Integer...
MUSEBOT_DISCORD_CHANNELS=

# The Discord channel ID or a comma separated list of channel IDs the bot is
# not allowed to reply in. If the bot is simultaneously allowed and disallowed
# to a channel, the disallowed rule takes precedence.
#
# Required: Optional
# Type:     Integer | Integer,Integer,Integer...
MUSEBOT_DISCORD_CHANNELS_DISALLOWED=

# Whether the the bot requires users to "@" mention them to reply.
#
# Required: Optional
# Type:     Boolean
# Default:  true
# Values:   true | false
MUSEBOT_REQUIRES_MENTION=true

# If MUSEBOT_REQUIRES_MENTION is false, what percentage of the time should it
# respond? Affects public responses only.
#
# Required: Optional
# Type:     Integer
# Default:  100
# Values:   1-100
MUSEBOT_RESPONSE_RATE=100

# Which roles, if any, are allowed to message the bots privately?
#
# Required: Optional
# Type:     String | String,String,String
MUSEBOT_PRIVATE_MESSAGE_ROLES=

# A custom error message to display when a render fails. Optional.
#
# Required: Optional
# Type:     String
# Default:  An error occurred while generating a response. Please try again
#           later.
MUSEBOT_ERROR_MESSAGE=

# Stable Diffusion Settings ####################################################
# Most of these settings are only required if MUSEBOT_FUNCTION is set to
# "images".

# Musebot supports SwarmUI or ComfyUI for image and/or video generation. Set to
# "None" to disable image/video generation.
#
# Required: Required
# Type:     String
# Values:   ComfyUI | None
MUSEBOT_STABLE_DIFFUSION_API_TYPE=None

# The base URL of the Stable Diffusion instance. This can also be a
# comma-separated list.
#
# Required: Required when MUSEBOT_FUNCTION=images
# Type:     URL | URL,URL,URL...
MUSEBOT_STABLE_DIFFUSION_HOSTS=

# Ollama Settings ##############################################################
# These settings are only required if MUSEBOT_FUNCTION is set to "text".

# The base URL of the Ollama instance. This can also be a comma-separated list.
#
# Required: Required when MUSEBOT_FUNCTION=text
# Type: URL | URL,URL,URL...
MUSEBOT_OLLAMA_HOSTS=

# The name of the large language model to use. This can also be a
# comma-separated list.
#
# Required: Required when MUSEBOT_FUNCTION=text
# Type:     String | String,String,String...
MUSEBOT_OLLAMA_MODELS=

# The system prompt used to help give the large language model context or a
# custom persona.
#
# Required: Optional
# Type:     String
MUSEBOT_OLLAMA_SYSTEM_PROMPT=

# Whether Musebot can stream the Ollama response or not. This determines
# if the response shows up all at once at the end of a generation or batches
# of tokens at a time. This can make it seem like Musebot is typing in real
# time.
#
# Required: Optional
# Type:     Boolean
# Default:  false
# Values:   true | false
MUSEBOT_OLLAMA_STREAMS_RESPONSE=false

# Cross-capable Settings #######################################################

# If both the Stable Diffusion and Ollama APIs are available, this provides the
# LLM prompt for the randomize button for the LLM. This can also be a
# pipe-delimited list (|).
#
# Required: Optional
# Type:     String | String|String|String...
# Default:  Describe something or someone with extraordinary detail.
MUSEBOT_STABLE_DIFFUSION_OLLAMA_PROMPTS=
