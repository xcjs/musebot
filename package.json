{
  "name": "musebot",
  "version": "8.5.0",
  "description": "A Discord bot that connects to various generative AI APIs.",
  "private": "true",
  "license": "XCJS Software License Agreement",
  "author": {
    "name": "Zackary Lowery",
    "email": "zlowery@xcjs.com",
    "url": "https://xcjs.com/"
  },
  "bin": "build/parcel/musebot.cjs",
  "main": "build/parcel/musebot.cjs",
  "type": "module",
  "pkg": {
    "assets": [
      "node_modules/@img/**/**"
    ],
    "targets": [
      "node24-linux-x64",
      "node24-win-x64"
    ],
    "outputPath": "build/pkg"
  },
  "scripts": {
    "prestart": "npm run parcel",
    "start": "node .",
    "start:only": "node .",
    "build": "tsc",
    "preparcel": "npm run build",
    "parcel": "parcel build build/tsc/src/app.js",
    "watch": "tsc -w",
    "prebuild:bin": "npm run parcel",
    "build:bin": "npx pkg .",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint --fix .",
    "test": "jest --silent"
  },
  "dependencies": {
    "comfy-ui-client": "^0.1.2",
    "cross-env": "^10.1.0",
    "discord.js": "14.23.2",
    "dotenv": "^17.2.3",
    "handlebars": "^4.7.8",
    "ollama": "^0.6.0",
    "parcel": "^2.15.4",
    "sharp": "^0.34.2",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.1",
    "@jest/globals": "^30.2.0",
    "@vuepress/bundler-vite": "^2.0.0-rc.26",
    "@vuepress/plugin-search": "^2.0.0-rc.125",
    "@vuepress/theme-default": "^2.0.0-rc.125",
    "@yao-pkg/pkg": "^6.9.0",
    "eslint": "^9.30.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.3.0",
    "jest": "^30.2.0",
    "jiti": "^2.4.2",
    "sass-embedded": "^1.98.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.36.0",
    "vuepress": "^2.0.0-rc.26"
  }
}
