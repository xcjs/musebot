{
  "name": "musebot",
  "version": "5.7.25",
  "description": "A Discord bot that connects to various generative AI APIs.",
  "private": "true",
  "license": "ISC",
  "bin": "build/parcel/musebot.cjs",
  "main": "build/parcel/musebot.cjs",
  "type": "module",
  "pkg": {
    "targets": [
      "node20-linux-x64",
      "node20-win-x64",
      "node20-macos-x64"
    ],
    "outputPath": "build/pkg"
  },
  "scripts": {
    "prestart": "npm run parcel",
    "start": "node .",
    "start:only": "node .",
    "build": "tsc",
    "preparcel": "npm run build",
    "parcel": "parcel build build/tsc/src/app.js",
    "dev": "tsc -w",
    "prebuild:bin": "npm run parcel",
    "build:bin": "npx pkg .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@yao-pkg/pkg": "^6.1.1",
    "discord.js": "14.16.1",
    "dotenv": "^16.3.1",
    "meklog": "^1.0.2",
    "ollama": "^0.5.2",
    "parcel": "^2.12.0",
    "typescript": "^5.5.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.6.0",
    "typescript-eslint": "^7.14.1"
  }
}
