{
  "name": "musebot",
  "version": "3.0.0",
  "description": "A Discord bot that connects to various generative AI APIs.",
  "private": "true",
  "license": "ISC",
  "main": "build/app.js",
  "type": "module",
  "scripts": {
    "prestart": "npm run build",
    "start": "node .",
    "start:only": "node .",
    "build": "tsc",
    "dev": "tsc -w",
    "prebuild:bin": "npm run build",
    "build:bin": "npx nexe -b --python /usr/bin/python3 -o bin/musebot build/bot.js",
    "lint": "eslint"
  },
  "dependencies": {
    "discord.js": "14.14.1",
    "dotenv": "^16.3.1",
    "meklog": "^1.0.2",
    "node-fetch": "^3.3.2",
    "typescript": "^5.5.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "globals": "^15.6.0",
    "nexe": "^4.0.0-rc.6",
    "typescript-eslint": "^7.14.1"
  }
}
