{
  "name": "musebot",
  "version": "7.0.3",
  "description": "A Discord bot that connects to various generative AI APIs.",
  "private": "true",
  "license": "ISC",
  "bin": "build/parcel/musebot.cjs",
  "main": "build/parcel/musebot.cjs",
  "type": "module",
  "pkg": {
    "assets": [
      "node_modules/@img/**/**"
    ],
    "targets": [
      "node20-linux-x64",
      "node20-win-x64",
      "node20-macos-x64"
    ],
    "outputPath": "build/pkg"
  },
  "scripts": {
    "prestart": "npm run parcel",
    "start": "node .",
    "start:only": "node .",
    "build": "tsc",
    "preparcel": "npm run build",
    "parcel": "parcel build build/tsc/src/app.js",
    "dev": "tsc -w",
    "prebuild:bin": "npm run parcel",
    "build:bin": "npx pkg .",
    "prebuild:docs": "npx recursive-copy-cli -w docs/assets/ build/docs/assets/",
    "build:docs": "npx sitedown --assets docs/assets/ docs/ -b build/docs/",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "jest --silent"
  },
  "dependencies": {
    "@yao-pkg/pkg": "^6.3.2",
    "comfy-ui-client": "^0.1.2",
    "cross-env": "^7.0.3",
    "discord.js": "14.18.0",
    "dotenv": "^16.4.7",
    "handlebars": "^4.7.8",
    "meklog": "^1.0.2",
    "ollama": "^0.5.14",
    "parcel": "^2.13.3",
    "sharp": "^0.34.1",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.26.0",
    "@jest/globals": "^29.7.0",
    "eslint": "^9.22.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "jiti": "^2.4.2",
    "recursive-copy-cli": "^1.0.20",
    "sitedown": "^5.1.3",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.26.1"
  }
}
