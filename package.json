{
  "name": "musebot",
  "version": "5.2.0",
  "description": "A Discord bot that connects to various generative AI APIs.",
  "private": "true",
  "license": "ISC",
  "main": "dist/musebot.cjs",
  "type": "module",
  "scripts": {
    "prestart": "npm run parcel",
    "start": "node .",
    "start:only": "node .",
    "build": "tsc",
    "preparcel": "npm run build",
    "parcel": "parcel build build/src/app.js",
    "dev": "tsc -w",
    "prebuild:bin": "npm run parcel",
    "build:bin": "npx nexe -b --python /usr/bin/python3 -o bin/musebot dist/musebot.cjs",
    "lint": "eslint",
    "clean": "mkdir -p .parcel-cache/ bin/ build/ dist/ && rm -r .parcel-cache/ bin/ build/ dist/"
  },
  "dependencies": {
    "discord.js": "14.16.1",
    "dotenv": "^16.3.1",
    "meklog": "^1.0.2",
    "ollama": "^0.5.2",
    "parcel": "^2.12.0",
    "typescript": "^5.5.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "globals": "^15.6.0",
    "nexe": "^4.0.0-rc.6",
    "typescript-eslint": "^7.14.1"
  }
}
