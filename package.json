{
  "name": "musebot",
  "version": "8.2.4",
  "description": "A Discord bot that connects to various generative AI APIs.",
  "private": "true",
  "license": "XCJS Software License Agreement",
  "author": {
    "name": "Zackary Lowery",
    "email": "zlowery@xcjs.com",
    "url": "https://xcjs.com/"
  },
  "bin": "build/parcel/musebot.cjs",
  "main": "build/parcel/musebot.cjs",
  "type": "module",
  "pkg": {
    "assets": [
      "node_modules/@img/**/**"
    ],
    "targets": [
      "node20-linux-x64",
      "node20-win-x64",
      "node20-macos-x64"
    ],
    "outputPath": "build/pkg"
  },
  "scripts": {
    "prestart": "npm run parcel",
    "start": "node .",
    "start:only": "node .",
    "build": "tsc",
    "preparcel": "npm run build",
    "parcel": "parcel build build/tsc/src/app.js",
    "watch": "tsc -w",
    "prebuild:bin": "npm run parcel",
    "build:bin": "npx pkg .",
    "prebuild:docs": "npx recursive-copy-cli -w docs/assets/ build/docs/assets/",
    "build:docs": "npx sitedown --assets docs/assets/ docs/ -b build/docs/",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "jest --silent"
  },
  "dependencies": {
    "@yao-pkg/pkg": "^6.5.1",
    "comfy-ui-client": "^0.1.2",
    "cross-env": "^7.0.3",
    "discord.js": "14.18.0",
    "dotenv": "^16.6.1",
    "handlebars": "^4.7.8",
    "ollama": "^0.5.16",
    "parcel": "^2.15.4",
    "sharp": "^0.34.2",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.1",
    "@jest/globals": "^29.7.0",
    "eslint": "^9.30.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.3.0",
    "jest": "^29.7.0",
    "jiti": "^2.4.2",
    "recursive-copy-cli": "^1.0.20",
    "sitedown": "^5.1.3",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.36.0"
  }
}
